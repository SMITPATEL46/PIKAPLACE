## Add environment variables here (if needed) and rename to ".env"

# ---------------- Backend (Flask) ----------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=pikaplace
MYSQL_USER=root
MYSQL_PASSWORD=your_password

# Comma-separated admin phone numbers in E.164 format (must match Firebase phone_number)
ADMIN_PHONE_NUMBERS=+911234567890,+919876543210

# Path to Firebase service account JSON (backend verification)
FIREBASE_SERVICE_ACCOUNT_JSON=./service-account.json

# Frontend base URL (used for PayPal return/cancel URLs)
FRONTEND_URL=http://localhost:5173
VITE_BACKEND_URL=http://localhost:5000

# PayPal Sandbox credentials
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ---------------- Frontend (Vite + Firebase Phone OTP) ----------------
